rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading from anywhere for the dashboard
    match /{document=**} {
      allow read: if true;
    }
    
    // Allow writes for simplicity in this dev environment
    // In production, you MUST restrict this to authenticated admins
    match /settings/{docId} {
      allow write: if true;
    }
    match /classes/{docId} {
      allow write: if true;
    }
    match /events/{docId} {
      allow write: if true;
    }
    match /notices/{docId} {
      allow write: if true;
    }
  }
}
